{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lead-payload.schema.json",
  "title": "LeadPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "nome",
    "whatsapp",
    "origem_trafego",
    "url_origem",
    "data_hora"
  ],
  "properties": {
    "nome": {
      "type": "string",
      "minLength": 2
    },
    "whatsapp": {
      "type": "string",
      "pattern": "^55[0-9]{10,11}$"
    },
    "produto_interesse": {
      "type": "string",
      "minLength": 1
    },
    "produto_id": {
      "type": "string",
      "minLength": 1
    },
    "assunto": {
      "type": "string",
      "enum": ["Duvida tecnica", "Pedidos", "Cadastro"]
    },
    "origem_trafego": {
      "type": "string",
      "minLength": 1
    },
    "url_origem": {
      "type": "string",
      "minLength": 1
    },
    "data_hora": {
      "type": "string",
      "minLength": 19
    }
  },
  "anyOf": [
    {
      "required": ["produto_interesse", "produto_id"]
    },
    {
      "required": ["assunto"]
    }
  ]
}
